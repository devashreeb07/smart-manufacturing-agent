# Copy this file to .env and fill in your real values.
# .env is gitignored -- never commit real credentials.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=manufacturing_agent
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# Optional -- only needed if you want LLM-enriched recommendations
GEMINI_API_KEY=
USE_LLM=0
